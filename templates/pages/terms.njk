{% extends "layouts/base.njk" %}

{% block content %}
  <section class="legal-section">
    <div class="container legal-shell">
      <p class="eyebrow">Terms</p>
      <h1>Website Terms</h1>
      <p>This site is a static brochure website for {{ site.businessName }}. Service details, coverage and contact information should be confirmed directly with the business before any booking is treated as final.</p>
      <p>All wording, images and contact details on the site can be updated through the admin console and rebuilt into static output.</p>
      <p>Use the published contact details for current availability, journey suitability and any specific booking terms.</p>
    </div>
  </section>
{% endblock %}
