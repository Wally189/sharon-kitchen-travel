<footer class="site-footer">
  <div class="container footer-shell">
    <div>
      {% if site.showAdminLink %}
        <a class="footer-admin-link" href="{{ site.adminLinkHref }}" aria-label="Admin login for {{ site.businessName }}"{% if site.adminLinkIsExternal %} target="_blank" rel="noreferrer"{% endif %}>{{ site.businessName }}</a>
      {% else %}
        <span class="footer-admin-link footer-admin-link-static">{{ site.businessName }}</span>
      {% endif %}
      <p>{{ site.footer.notice }}</p>
    </div>
    <div class="waylight-legal-block" data-waylight-legal>
      <p class="waylight-legal-links">
        <a href="{{ site.gdprHref }}">GDPR</a> |
        <a href="{{ site.privacyHref }}">Privacy</a> |
        <a href="{{ site.termsHref }}">Terms</a>
      </p>
      <p class="waylight-legal-location">{{ site.footer.legalLocation }}</p>
      <p class="waylight-legal-copyright">&copy; {{ year }} <a href="https://www.waylight-atlantic.co.uk/" rel="noopener noreferrer" target="_blank">Waylight Atlantic</a></p>
    </div>
  </div>
</footer>
